{
  "rewrites": [
    {
      "source": "/dograh-api/:path*",
      "destination": "https://api.dograh.com/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.tevrixai.com" }],
      "destination": "https://tevrixai.com/:path*",
      "permanent": true
    }
  ]
}
